# ── Backend ────────────────────────────────────────────────────────────────
# Copy this file's backend section to backend/.env and fill in real values.
# Never commit actual .env files to git.

PORT=5001
NODE_ENV=development

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/shiftscheduler

# JWT — use a random string of at least 32 characters
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=24h

# CORS — must match the frontend dev server origin
ALLOWED_ORIGIN=http://localhost:5173

# ── Frontend ───────────────────────────────────────────────────────────────
# Vite only exposes variables prefixed with VITE_ to browser code.
# Add a frontend/.env file for these.

# Backend API base URL (used by Vite proxy; keep as-is for local dev)
VITE_API_BASE_URL=http://localhost:5001/api/v1
